{
  "name": "hv-launcher",
  "version": "0.1.0",
  "description": "Decky readiness and hypervisor game-session manager",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && rollup -c",
    "watch": "npm run typecheck && rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "GPL-2.0-only",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/plugin-replace": "^5.0.7",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
