{
  "name": "hv-launcher",
  "version": "1.0.0",
  "description": "Decky readiness and hypervisor game-session manager",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && rollup -c",
    "lint:commits": "commitlint --verbose",
    "release": "semantic-release",
    "release:preview": "semantic-release --dry-run",
    "watch": "npm run typecheck && rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "GPL-2.0-only",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/plugin-replace": "^5.0.7",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.9",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "rollup": "^4.53.3",
    "semantic-release": "25.0.7",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
